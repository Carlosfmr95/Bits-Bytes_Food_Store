# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno (NUNCA commitear secretos)
# Se ignoran .env y cualquier .env.*, salvo las plantillas .env.example / .env.test
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Python / Backend
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Entornos virtuales
.venv/
venv/
env/
ENV/

# Caches de tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ─────────────────────────────────────────────────────────────────────────────
# Node / Frontend
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Editores / Sistema operativo
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
