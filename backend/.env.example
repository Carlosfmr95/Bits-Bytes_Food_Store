# ── Base de datos (PostgreSQL) ─────────────────────────────────────────────────
postgres_user=postgres
postgres_password=password
postgres_db=food_store_db
postgres_host=localhost
postgres_port=5433

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generá una clave propia: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Entorno / Logging ──────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── Rate limiting (login/register) ──────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AUTH_BURST=5
RATE_LIMIT_AUTH_LOCKOUT_SECONDS=900

# ── MercadoPago ──────────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_URL=https://<ngrok>.ngrok-free.app/api/v1/pagos/webhook
NGROK_URL=https://<ngrok>.ngrok-free.app
FRONTEND_URL=http://localhost:5174

# ── Cloudinary (upload de imágenes) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=mi-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmn
CLOUDINARY_FOLDER=foodstore
